{
  "title": "LendStream — Loan Processing Pipeline",
  "uid": "lendstream-main",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Rate (per service)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (job) (rate(http_requests_total[1m]))",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 2,
      "title": "HTTP Error Rate",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (job) (rate(http_requests_total{status_code=~\"5..\"}[1m]))",
          "legendFormat": "{{job}} errors"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 3,
      "title": "Request Latency p99 (per service)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (job, le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{job}} p99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 4,
      "title": "Kafka Events Processed (per service)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (job, topic, status) (rate(kafka_events_processed_total[1m]))",
          "legendFormat": "{{job}} / {{topic}} [{{status}}]"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 5,
      "title": "Total Loans Submitted",
      "type": "stat",
      "gridPos": { "x": 0, "y": 16, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(http_requests_total{job=\"loan-service\", route=\"/\", method=\"POST\", status_code=\"201\"})",
          "legendFormat": "Loans"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": 0 }] } }
      }
    },
    {
      "id": 6,
      "title": "Kafka DLQ Events",
      "type": "timeseries",
      "gridPos": { "x": 6, "y": 16, "w": 18, "h": 4 },
      "targets": [
        {
          "expr": "sum by (job) (rate(kafka_events_processed_total{status=\"error\"}[5m]))",
          "legendFormat": "{{job}} DLQ events/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "color": { "fixedColor": "red", "mode": "fixed" } }
      }
    },
    {
      "id": 7,
      "title": "Node.js Heap Used",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "nodejs_heap_size_used_bytes",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 8,
      "title": "Node.js Event Loop Lag",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "nodejs_eventloop_lag_seconds",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } }
      }
    }
  ]
}
